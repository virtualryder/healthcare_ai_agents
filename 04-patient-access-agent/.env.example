# ── Agent 04 — Patient Access ────────────────────────────────────────────────
EXTRACT_MODE=demo                 # demo (no LLM) | live
CONNECTOR_MODE=fixture            # fixture | live
LLM_PROVIDER=anthropic            # anthropic | bedrock
# ANTHROPIC_API_KEY=...
# --- Bedrock (in-account, no PHI egress; under AWS BAA) ---
# BEDROCK_REGION=us-east-1
# BEDROCK_GUARDRAIL_ID=...         # REQUIRED in production
# ENVIRONMENT=production
# --- Live connectors (scheduling, registration, payer eligibility) ---
# SCHEDULING_BASE_URL=https://sched.health.example.org
# REGISTRATION_BASE_URL=https://reg.health.example.org
# PAYER_BASE_URL=https://payer.example.com/fhir
# GATEWAY_AUDIT_JSONL=/var/log/hpp/gateway-audit.jsonl
