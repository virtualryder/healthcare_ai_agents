# ── Agent 07 — Care Management & Population Health ────────────────────────────
EXTRACT_MODE=demo                 # demo (no LLM) | live
CONNECTOR_MODE=fixture            # fixture | live
LLM_PROVIDER=bedrock              # bedrock (default, in-account/PrivateLink under BAA) | anthropic (external API — needs ALLOW_EXTERNAL_LLM=1)
# ANTHROPIC_API_KEY=...
# --- Bedrock (via PrivateLink; no PHI egress to external AI APIs; under AWS BAA) ---
# BEDROCK_REGION=us-east-1
# BEDROCK_GUARDRAIL_ID=...         # REQUIRED in production
# ENVIRONMENT=production
# --- Live connectors (care management, EHR/HealthLake, consent) ---
# CAREPLAN_BASE_URL=https://caremgmt.example.org
# EHR_BASE_URL=https://ehr.health.example.org/fhir
# CONSENT_BASE_URL=https://consent.example.org
# GATEWAY_AUDIT_JSONL=/var/log/hpp/gateway-audit.jsonl
